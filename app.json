{
  "expo": {
    "name": "Flatvio",
    "slug": "flatvio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08090A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.flatvio.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Flatvio uses your camera to capture move-in and repair photos.",
        "NSPhotoLibraryUsageDescription": "Flatvio accesses your photos to upload property proof images.",
        "NSContactsUsageDescription": "Flatvio uses your contacts to help you quickly invite tenants by phone number."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "in.flatvio.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_CONTACTS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "scheme": "flatvio",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#08090A"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
