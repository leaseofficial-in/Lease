# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Capacitor — Android build artifacts (keep source, exclude generated)
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
android/app/release/
android/app/*.keystore
android/*.keystore

# Capacitor — iOS build artifacts
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/DerivedData/
ios/.idea/

# Capacitor static export
/out/
